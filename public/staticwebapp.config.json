{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/images/*.{png,jpg,gif,ico,webp,svg}",
      "/_nuxt/*",
      "/*.{css,js,json,woff,woff2,ttf,eot}"
    ]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache, no-store, must-revalidate"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
